# --- Browser / Vite (safe to set in Bolt.new, Vercel, Netlify, GitHub Actions build) ---
# Supabase
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use either the legacy anon JWT (eyJ...) OR the new publishable key (sb_publishable_...):
VITE_SUPABASE_ANON_KEY=
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Bootstrap admin if customers.role is missing (comma-separated). Prefer SQL: public.customers.role = 'admin'.
# ⚠️  WARNING: This is client-side accessible. Use only for local dev. In production, set role via SQL.
# VITE_ADMIN_EMAILS=you@yourdomain.com

# ⚠️  DANGER: If PAYMENT_LINK_CREATE_SECRET is set on the Edge Function, set the same value here
# so the admin Payment links UI can create links (exposes secret to the browser — local dev only).
# DO NOT SET THIS IN PRODUCTION. Use server-side auth instead.
# VITE_PAYMENT_LINK_CREATE_SECRET=

# Square Web Payments SDK — leave empty for real orders in Supabase without card capture (payment pending).
# VITE_SQUARE_APPLICATION_ID=
# VITE_SQUARE_ENVIRONMENT=sandbox
# VITE_SQUARE_LOCATION_ID=

# Optional: Pexels — homepage category strip (see useCategoryStripImages).
# VITE_PEXELS_API_KEY=

# --- Payment links (Edge Functions secrets — Dashboard or `supabase secrets set`) ---
# LAMIN / server callers: use PAYMENT_LINK_BEARER OR PAYMENT_LINK_CREATE_SECRET (same value; Bearer or x-payment-link-secret).
# PAYMENT_LINK_BEARER=
# PAYMENT_LINK_CREATE_SECRET=
# Optional: force 6-digit codes for all links (not only metadata.source=lamin)
# PAYMENT_LINK_REQUIRE_SIX_DIGIT_CODE=true

# FRONTEND_URL: Required for CORS in Edge Functions. Set to your production domain(s).
# FRONTEND_URL=https://your-site.com   # fallback base for payment_url if Origin header missing

# Browser tab title on /pay/:id only (white-label; avoids showing main storefront name).
# VITE_PAY_PAGE_TITLE=Secure checkout

# --- Embedded pay (iframe on partner sites) ---
# Comma-separated origins allowed to handshake via postMessage (must match the parent page URL exactly: scheme + host + port).
# Include both apex and www if the partner uses either. Required on production Vercel or the iframe loads but resize/success messages fail.
# VITE_EMBED_PARENT_ORIGINS=http://localhost:5173,https://lamininpeplab.com.au,https://www.lamininpeplab.com.au

# Shown on /embed/pay/* (e.g. disclosure that checkout is processed by CoreForge).
# VITE_PAY_TRUST_DISCLOSURE=Checkout is secured by CoreForge Payments.

# Partner name in embed copy (e.g. LAMININ). Default: LAMININ
# VITE_PAY_PARTNER_LABEL=LAMININ

# --- Local Supabase CLI only (never VITE_ — never commit real values) ---
# SUPABASE_ACCESS_TOKEN=   # supabase login / link / db push
# Full deploy checklist: see DEPLOYMENT.md
